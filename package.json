{
  "name": "watchalong",
  "version": "0.1.0",
  "description": "Local desktop app for synchronized reaction watchalong playback.",
  "main": "out/main/index.js",
  "author": "WatchAlong",
  "license": "MIT",
  "scripts": {
    "dev": "electron-vite dev",
    "postinstall": "npm ci --omit=dev --prefix resources/tools/patreon-dl",
    "typecheck": "tsc --noEmit -p tsconfig.node.json && tsc --noEmit -p tsconfig.web.json",
    "test": "vitest run",
    "build": "npm run postinstall && npm run typecheck && electron-vite build",
    "dist": "npm run build && electron-builder"
  },
  "dependencies": {
    "lucide-react": "^0.468.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "^6.4.8",
    "@testing-library/react": "^16.0.1",
    "@types/node": "^20.14.12",
    "@types/react": "^18.3.3",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.3.1",
    "electron": "^42.0.0",
    "electron-builder": "^25.0.5",
    "electron-vite": "^5.0.0",
    "jsdom": "^24.1.1",
    "typescript": "^5.5.4",
    "vite": "^5.4.2",
    "vitest": "^2.0.5"
  },
  "build": {
    "appId": "local.watchalong.app",
    "productName": "WatchAlong",
    "directories": {
      "output": "release"
    },
    "files": [
      "out/**/*",
      "package.json"
    ],
    "extraResources": [
      {
        "from": "ATTRIBUTION.md",
        "to": "ATTRIBUTION.md"
      }
    ],
    "win": {
      "target": "nsis",
      "extraResources": [
        {
          "from": "resources/tools/yt-dlp",
          "to": "tools/yt-dlp",
          "filter": [
            "yt-dlp.exe"
          ]
        },
        {
          "from": "resources/tools/ffmpeg",
          "to": "tools/ffmpeg",
          "filter": [
            "ffmpeg.exe",
            "ffprobe.exe"
          ]
        },
        {
          "from": "resources/tools/node",
          "to": "tools/node",
          "filter": [
            "node.exe"
          ]
        },
        {
          "from": "resources/tools/patreon-dl",
          "to": "tools/patreon-dl",
          "filter": [
            "package.json",
            "node_modules/**/*",
            "!node_modules/.bin{,/**/*}",
            "!node_modules/**/{test,tests,__tests__,example,examples,coverage,doc,docs,scripts}{,/**/*}",
            "!node_modules/**/*.{map,ts,tsx,md,markdown}",
            "!node_modules/**/{package-lock.json,yarn.lock,pnpm-lock.yaml,npm-shrinkwrap.json}"
          ]
        }
      ]
    },
    "mac": {
      "target": "dmg",
      "category": "public.app-category.video",
      "extraResources": [
        {
          "from": "resources/tools/yt-dlp",
          "to": "tools/yt-dlp",
          "filter": [
            "yt-dlp_macos"
          ]
        },
        {
          "from": "resources/tools/ffmpeg",
          "to": "tools/ffmpeg",
          "filter": [
            "ffmpeg-darwin-${arch}"
          ]
        },
        {
          "from": "resources/tools/node",
          "to": "tools/node",
          "filter": [
            "node-darwin-${arch}"
          ]
        },
        {
          "from": "resources/tools/patreon-dl",
          "to": "tools/patreon-dl",
          "filter": [
            "package.json",
            "node_modules/**/*",
            "!node_modules/.bin{,/**/*}",
            "!node_modules/**/{test,tests,__tests__,example,examples,coverage,doc,docs,scripts}{,/**/*}",
            "!node_modules/**/*.{map,ts,tsx,md,markdown}",
            "!node_modules/**/{package-lock.json,yarn.lock,pnpm-lock.yaml,npm-shrinkwrap.json}"
          ]
        }
      ]
    }
  }
}
